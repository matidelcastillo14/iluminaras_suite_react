# Copia este archivo a `.env` y ajusta los valores según tu entorno local.

# Puerto en el que se ejecutará la API Flask (React paralelo)
PORT=5914

# URL de la base de datos. Ajusta según tu servidor PostgreSQL.
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/base_de_datos

# Clave secreta para sesiones
SECRET_KEY=cambiar-esta-clave

# Configuración de Odoo (solo lectura). Si no se usa, puede quedar en blanco.
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=
:root{
  --brand:#49C8C4;
  --brand2:#2aa7a3;
  --bg:#f4f7f7;
  --text:#101214;
  --muted:#6b7280;
  --card:#ffffff;
  --border:#e6e8eb;
}

*{ box-sizing:border-box; }
body{ margin:0; font-family: Arial, Helvetica, sans-serif; background:var(--bg); color:var(--text); padding-bottom:72px; }

.fx-header{ position:sticky; top:0; z-index:50; background:var(--brand); color:#fff; padding:12px 12px; display:flex; align-items:center; justify-content:space-between; }
.fx-left{ display:flex; align-items:center; gap:10px; }
.fx-back{ color:#fff; text-decoration:none; font-size:20px; padding:4px 8px; border-radius:10px; background: rgba(255,255,255,.18); }
.fx-title{ font-weight:700; font-size:16px; }
.fx-right{ display:flex; align-items:center; gap:10px; }
.fx-user{ font-size:12px; opacity:.95; }
.fx-link{ color:#fff; text-decoration:none; font-size:13px; opacity:.95; }

.fx-main{ padding:12px; max-width: 720px; margin: 0 auto; }

/* Tabs inferiores */
.fx-tabs{ position:fixed; left:0; right:0; bottom:0; z-index:60; display:flex; gap:6px; padding:10px 10px calc(10px + env(safe-area-inset-bottom)); background:#fff; border-top:1px solid var(--border); }
.fx-tab{ flex:1 1 0; text-align:center; padding:10px 8px; border-radius:14px; text-decoration:none; font-weight:700; font-size:13px; color:var(--text); background: #f3f4f6; border:1px solid var(--border); }
.fx-tab.active{ background: var(--brand2); border-color: var(--brand2); color:#fff; }
.fx-tab.disabled{ opacity:.45; pointer-events:none; }

.fx-card{ background:var(--card); border:1px solid var(--border); border-radius:16px; padding:12px; margin: 10px 0; }
.fx-list{ display:flex; flex-direction:column; gap:10px; margin: 10px 0 100px; }

.fx-row{ display:flex; gap:10px; align-items:center; }
.fx-space{ justify-content:space-between; }

.fx-btn{ border:1px solid rgba(255,255,255,.0); border-radius:14px; padding:10px 12px; background: rgba(255,255,255,.18); color:#fff; font-size:14px; font-weight:600; cursor:pointer; }
.fx-btn.ghost{ background:#fff; color:var(--text); border:1px solid var(--border); }
.fx-btn.primary{ background:var(--brand2); color:#fff; border:1px solid var(--brand2); }
.fx-btn.arriving{ background:#e9f1ff; color:#1d4ed8; border:1px solid #cfe1ff; }
.fx-pill{ font-size:12px; padding:6px 10px; border-radius:999px; background:#e7f7f6; color:#0f766e; border:1px solid #c7efec; }

.fx-muted{ color:var(--muted); font-size:13px; }
.fx-big{ font-size:18px; font-weight:700; }
.fx-idweb{ font-size:18px; font-weight:800; }

.fx-msg{ padding:10px 12px; border-radius:12px; margin:10px 0; border:1px solid transparent; }
.fx-msg-error{ background:#ffe9e9; border-color:#ffb6b6; color:#7f1d1d; }
.fx-msg-info{ background:#e9f1ff; border-color:#b6d0ff; }

.fx-community{ display:flex; gap:10px; align-items:center; padding:12px; border-radius:16px; border:1px solid var(--border); background:#fff; text-decoration:none; color:var(--text); }
.fx-community-bullet{ width:12px; height:12px; border-radius:999px; }
.fx-community-name{ font-size:16px; font-weight:700; }

.fx-stop{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:12px; border-radius:16px; border:1px solid var(--border); background:#fff; text-decoration:none; color:var(--text); }
.fx-stop-addr{ font-weight:700; }
.fx-stop-main{ flex: 1 1 auto; }
.fx-stop-actions{ flex: 0 0 auto; }

/* Scanner */
.fx-scan-wrap{ position:relative; width:100%; height: calc(100vh - 110px); max-height: 520px; overflow:hidden; border-radius:18px; background:#000; }
.fx-video{ width:100%; height:100%; object-fit:cover; }
.fx-brackets{ position:absolute; inset:0; pointer-events:none; }
.fx-bracket{ position:absolute; width:44px; height:44px; border:4px solid rgba(73,200,196,.85); }
.fx-bracket.tl{ top:18px; left:18px; border-right:none; border-bottom:none; border-top-left-radius:14px; }
.fx-bracket.tr{ top:18px; right:18px; border-left:none; border-bottom:none; border-top-right-radius:14px; }
.fx-bracket.bl{ bottom:18px; left:18px; border-right:none; border-top:none; border-bottom-left-radius:14px; }
.fx-bracket.br{ bottom:18px; right:18px; border-left:none; border-top:none; border-bottom-right-radius:14px; }
.fx-scan-actions{ position:absolute; top:12px; right:12px; display:flex; gap:8px; }

.fx-sheet{ position:fixed; left:0; right:0; bottom:0; background:#fff; border-top:1px solid var(--border); border-radius:18px 18px 0 0; padding:10px 14px calc(14px + 64px + env(safe-area-inset-bottom)); max-width: 720px; margin:0 auto; box-shadow: 0 -10px 30px rgba(0,0,0,.12); }
.fx-sheet-handle{ width:44px; height:5px; border-radius:999px; background:#d7d7d7; margin: 4px auto 10px; }
.fx-sheet-row{ display:flex; align-items:flex-start; justify-content:space-between; gap:10px; }
.fx-sheet-title{ font-size:18px; font-weight:800; }
.fx-cart{ margin:10px 0; max-height: 220px; overflow:auto; }
.fx-cart-item{ padding:10px; border:1px solid var(--border); border-radius:14px; margin:8px 0; display:flex; align-items:center; justify-content:space-between; gap:10px; }
.fx-cart-id{ font-weight:800; }
.fx-cart-x{ background:#fff; border:1px solid var(--border); border-radius:12px; padding:8px 10px; cursor:pointer; }

.fx-dialog::backdrop{ background: rgba(0,0,0,.4); }
.fx-dialog{ border:none; border-radius:16px; padding:0; width: min(520px, 92vw); }
.fx-dialog-form{ padding:14px; }
.fx-dialog-title{ font-weight:800; font-size:16px; margin-bottom:8px; }
textarea, input{ width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:14px; font-size:14px; }
label{ display:block; font-size:12px; color:var(--muted); margin: 10px 0 6px; }

/* Map */
.fx-map{ height: calc(100vh - 140px); min-height: 420px; border-radius:16px; border:1px solid var(--border); overflow:hidden; }
.fx-sheet-map{ max-width: 520px; }
